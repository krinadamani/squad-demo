# LLM provider: openai | azure-openai | ollama | fallback
LLM_PROVIDER=azure-openai

# OpenAI settings
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI settings
AZURE_OPENAI_AUTH_MODE=entra
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your_deployment_name
AZURE_OPENAI_API_VERSION=2024-10-21
# Optional if auth mode is entra and Azure CLI is unavailable
AZURE_OPENAI_BEARER_TOKEN=your_bearer_token_here
# Set false to disable Azure CLI token fallback
AZURE_OPENAI_USE_AZ_CLI=true

# Ollama settings
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434
